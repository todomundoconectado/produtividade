    {
      "parameters": {
        "jsCode": "const meta    = $('Extrair Status').first().json;\nconst tarefa  = $('Buscar Tarefa ClickUp').first().json;\nconst sessoes = $input.all().map(i => i.json);\n\nconst task_id    = meta.task_id;\nconst task_name  = tarefa.name || ('Tarefa #' + task_id);\nconst responsavel = meta.responsavel;\nconst entrada_em_andamento = new Date().toISOString();\nconst total_anterior = sessoes.reduce((sum, s) => sum + (s.minutos_sessao || 0), 0);\n\nlet due_date = null;\nif (tarefa.due_date) {\n  due_date = new Date(parseInt(tarefa.due_date)).toISOString();\n}\n\nreturn [{ json: {\n  task_id,\n  task_name,\n  responsavel,\n  entrada_em_andamento,\n  due_date,\n  total_minutos_acumulado: total_anterior\n} }];"
      },
