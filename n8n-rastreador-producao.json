    {
      "parameters": {
        "jsCode": "const todos = $input.all();\nif (!todos || todos.length === 0) {\n  const tid = $('Extrair Status').first().json.task_id;\n  throw new Error('Nenhuma sessao aberta encontrada para task_id: ' + tid);\n}\nconst item = todos[0].json;\n\nconst entradaRaw = item.entrada_em_andamento || item.created_at;\nif (!entradaRaw) return [];\n\nconst entrada = new Date(entradaRaw);\nconst saida   = new Date();\nconst minutos_sessao = Math.round((saida - entrada) / 60000);\n\nconst total_anterior = item.total_minutos_acumulado || 0;\nconst total_minutos_acumulado = total_anterior + minutos_sessao;\n\nreturn [{ json: {\n  registro_id: item.id,\n  saida_de_andamento: saida.toISOString(),\n  minutos_sessao,\n  total_minutos_acumulado\n} }];"
      },
