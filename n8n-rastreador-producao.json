    {
      "parameters": {
        "jsCode": "const body = $json.body;\nconst item = body.history_items?.[0];\nif (!item) return [{ json: { skip: true } }];\n\nconst afterRaw  = item.after?.status  ?? item.after  ?? null;\nconst beforeRaw = item.before?.status ?? item.before ?? null;\n\nfunction toStr(v) {\n  if (v === null || v === undefined) return '';\n  if (typeof v === 'object') return String(v.status || '');\n  return String(v);\n}\n\nconst after  = toStr(afterRaw).toLowerCase().trim();\nconst before = toStr(beforeRaw).toLowerCase().trim();\n\nconst task_id     = body.task_id;\nconst responsavel = item.user?.username || 'Desconhecido';\n\nconst entrou = after  === 'tarefas em andamento';\nconst saiu   = before === 'tarefas em andamento' && after !== 'tarefas em andamento';\n\nreturn [{ json: { task_id, responsavel, entrou, saiu, after, before } }];"
      },
